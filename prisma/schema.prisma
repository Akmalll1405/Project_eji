generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(PROJECT_MANAGER)
  createdAt    DateTime      @default(now())
  projects     Project[]
  transactions Transaction[]
}

model Project {
  id              String    @id @default(cuid())
  nama            String
  jenis           String?
  nilai           Float?
  penanggungjawab String?
  wilayah         String?
  sektor          String?
  tanggalMulai    DateTime?
  tanggalSelesai  DateTime?
  status          StatusProyek    @default(PERENCANAAN)
  isApproved      Boolean   @default(false) 
  userId          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User?     @relation(fields: [userId], references: [id])
  documents       Document[]
  donors          Donor[]
  transactions    Transaction[]
  Kegiatan        Kegiatan[]
}

model Donor {
  id              String   @id @default(cuid())
  nama            String
  jenis           String
  penanggungjawab String
  wilayah         String
  createdAt       DateTime @default(now())
  projectId       String
  alamat          String?
  tahunPendirian  Int?
  lamaUsaha       Int?
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Document {
  id            String    @id @default(cuid())
  jenisDokumen  String
  fileUrl       String
  fileName      String
  tanggalUpload DateTime  @default(now())
  projectId     String
  status        String    @default("PENDING")
  catatanAdmin  String?
  approvedAt    DateTime?
  approvedBy    String?
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                          String    @id @default(cuid())
  jenisPembayaran             String?
  keterangan                  String?
  nomorRekening               String?
  bankTujuan                  String?
  jumlah                      Float     @default(0)
  tanggalPembayaran           DateTime?
  buktiBayarUrl               String?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime? @updatedAt
  projectId                   String
  userId                      String?
  namaProgram                 String?
  kegiatan                    String?
  staffCA                     String?
  tanggalPengajuan            DateTime?
  tanggalPertanggungjawaban   DateTime?
  kelengkapanDokumen          String?   @default("Lengkap")
  statusTransaksi             String?   @default("Transfer successful")
  statusApproval              String?   @default("PENDING")
  catatanAdmin                String?
  project                     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                        User?     @relation(fields: [userId], references: [id])
}

model Kegiatan {
  id              String   @id
  namaKegiatan    String
  tanggalKegiatan DateTime
  fotoUrl         String?
  fotoName        String?
  projectId       String
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  PROJECT_MANAGER
}

enum StatusProyek {
  PERENCANAAN
  BERJALAN
  SELESAI
}

enum JenisDokumen {
  PROPOSAL
  KONTRAK_KERJA
  SURAT_IZIN
  DOKUMENTASI_KEGIATAN
  LAPORAN_PEKERJAAN
}

enum JenisPembayaran {
  TUNAI
  NONTUNAI
}
